<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-02beaa60-cd6e-4f66-b66e-0e7f2c7b3485@mhtml.blink">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GridGarrison EV Cockpit</title>
  
<link rel="stylesheet" href="chrome-extension://726f083e-c54f-41ef-b131-462bbb49c973/app/content-style.css"></head>
<body>
  <div class="wrap">
    <div class="header">
      <div class="title">
        <h1>EV Dynamic Cockpit</h1>
        <p>Clear demo flow + dynamic EV visuals: connect, profile, charge, monitor telemetry, and close session.</p>
      </div>
      <div id="connectionPill" class="status-pill ok">EV Online</div>
    </div>

    <div class="flow-track">
      <div id="stepConnect" class="flow-step done">
        <div class="num">Step 1</div>
        <div class="name">Connect EV</div>
      </div>
      <div id="stepProfile" class="flow-step done">
        <div class="num">Step 2</div>
        <div class="name">Pick Profile</div>
      </div>
      <div id="stepStart" class="flow-step active">
        <div class="num">Step 3</div>
        <div class="name">Start Charging</div>
      </div>
      <div id="stepMeter" class="flow-step">
        <div class="num">Step 4</div>
        <div class="name">Stream Energy</div>
      </div>
      <div id="stepEnd" class="flow-step">
        <div class="num">Step 5</div>
        <div class="name">End Session</div>
      </div>
    </div>

    <div class="grid">
      <div class="panel span-12">
        <div class="row" style="margin-top:0;">
          <div class="col-8">
            <label>Simulator URL</label>
            <input id="apiBase" value="http://localhost:8080">
            <div class="hint">Change this only if simulator runs on another port.</div>
          </div>
          <div class="col-4">
            <label>Live refresh (seconds)</label>
            <div class="row" style="margin-top:0;">
              <div class="col-6"><input id="pollSec" type="number" min="1" value="3"></div>
              <div class="col-6"><button id="togglePoll" class="primary">Auto: ON</button></div>
            </div>
            <button id="refreshAll" class="ok">Refresh Dashboard</button>
          </div>
        </div>
      </div>

      <div class="panel span-12 hero">
        <div class="hero-grid">
          <div>
            <h3>Live EV State</h3>
            <p class="hint" style="margin-top:4px;">This panel mirrors what judges should watch first during the demo flow.</p>
            <div class="ev-state">
              <div class="state-card">
                <div class="label">Connection</div>
                <div id="kpiConnected" class="value"><span class="badge ok">Connected</span></div>
              </div>
              <div class="state-card">
                <div class="label">Current Session</div>
                <div id="kpiTx" class="value mono">-</div>
              </div>
              <div class="state-card">
                <div class="label">Drive Profile</div>
                <div id="kpiProfile" class="value">normal</div>
              </div>
              <div class="state-card">
                <div class="label">Scenario</div>
                <div id="kpiScenario" class="value">Idle</div>
              </div>
            </div>
          </div>

          <div class="ev-model-wrap">
            <h3>EV Model</h3>
            <div class="road">
              <div id="evCar" class="ev-car moving">
                <div class="car-body"></div>
                <div class="car-window"></div>
                <div class="wheel left"></div>
                <div class="wheel right"></div>
              </div>
              <div class="charge-beam"></div>
            </div>
            <div class="hint" id="vehicleModeText" style="margin-top:8px;">Vehicle mode: Driving (21 km/h)</div>
          </div>
        </div>

        <div class="telemetry">
          <div class="telemetry-card">
            <div class="label">Battery</div>
            <div id="batteryText" class="value">24%</div>
            <div class="progress"><div id="batteryFill" class="progress-fill" style="width: 24%;"></div></div>
          </div>
          <div class="telemetry-card">
            <div class="label">Temperature</div>
            <div id="tempText" class="value">26.4°C</div>
            <div class="progress"><div id="tempFill" class="progress-fill temp-fill" style="width: 8.53333%;"></div></div>
          </div>
          <div class="telemetry-card">
            <div class="label">Speed</div>
            <div id="speedText" class="value">21 km/h</div>
            <div class="progress"><div id="speedFill" class="progress-fill speed-fill" style="width: 13.125%;"></div></div>
          </div>
          <div class="telemetry-card">
            <div class="label">Charge Power</div>
            <div id="powerText" class="value">0 kW</div>
            <div class="progress"><div id="powerFill" class="progress-fill power-fill" style="width: 0%;"></div></div>
          </div>
        </div>
      </div>

      <div class="panel span-8">
        <h3>Guided Demo Controls</h3>
        <p class="hint" style="margin-top:6px;">Follow top-to-bottom for a clean story: connect → profile → charge → updates → finish.</p>

        <div class="row">
          <div class="col-6"><button id="connectBtn" class="ok">Step 1: Connect EV</button></div>
          <div class="col-6"><button id="disconnectBtn" class="danger">Disconnect EV</button></div>

          <div class="col-8">
            <label>Step 2: Choose profile</label>
            <select id="profileSelect"><option value="fast">Fast charging demo</option><option value="normal">Normal driving</option></select>
          </div>
          <div class="col-4"><label>&nbsp;</label><button id="setProfileBtn" class="primary">Apply Profile</button></div>

          <div class="col-8">
            <label>Step 3: Start session ID (optional)</label>
            <input id="txId" placeholder="leave blank to auto-create">
          </div>
          <div class="col-4"><label>&nbsp;</label><button id="txStartBtn" class="ok">Start Charging</button></div>

          <div class="col-4">
            <label>Step 4: Energy per update (kWh)</label>
            <input id="meterKwh" type="number" step="0.1" value="1.5">
          </div>
          <div class="col-4"><label>&nbsp;</label><button id="txMeterBtn" class="primary">Send 1 Update</button></div>
          <div class="col-4"><label>&nbsp;</label><button id="send3MetersBtn" class="warn">Send 3 Updates</button></div>

          <div class="col-8">
            <label>Step 5: End session total (kWh)</label>
            <input id="totalKwh" type="number" step="0.1" value="0.0">
          </div>
          <div class="col-4"><label>&nbsp;</label><button id="txEndBtn" class="danger">End Charging</button></div>
        </div>
      </div>

      <div class="panel span-4">
        <h3>Scenario Runner</h3>
        <div class="hint" style="margin-top:6px;">Narrative shortcuts for judges and technical walkthroughs.</div>
        <div class="row">
          <div class="col-12">
            <label>Scenario</label>
            <select id="scenarioSelect">
              <option value="normalCharging">Normal charging</option>
              <option value="firmwareTamper">Tampered firmware</option>
              <option value="reconnectLoop">Unstable connection</option>
              <option value="isoPnCHappyPath">ISO-15118 Plug &amp; Charge (valid)</option>
              <option value="isoPnCCertMissing">ISO-15118 Plug &amp; Charge (missing cert)</option>
            </select>
          </div>
          <div class="col-12"><button id="runScenarioBtn" class="primary">Run Scenario</button></div>
          <div class="col-12"><button id="stopScenarioBtn" class="warn">Stop Scenario</button></div>
        </div>

        <h3 style="margin-top:14px;">Firmware Signal</h3>
        <div class="row">
          <div class="col-12">
            <label>Firmware status</label>
            <select id="fwStatus">
              <option>Downloaded</option>
              <option>DownloadFailed</option>
              <option>Downloading</option>
              <option>Idle</option>
            </select>
          </div>
          <div class="col-12">
            <label>Firmware hash</label>
            <input id="fwHash" value="abc123def456ghi789jkl012mno345pqr">
          </div>
          <div class="col-12"><button id="fwSendBtn" class="primary">Send Firmware Signal</button></div>
        </div>

        <div class="row" style="margin-top:10px;">
          <div class="col-6">
            <div class="state-card">
              <div class="label">Energy Sent</div>
              <div id="kpiEnergy" class="value">0.00 kWh</div>
            </div>
          </div>
          <div class="col-6">
            <div class="state-card">
              <div class="label">Meter Updates</div>
              <div id="kpiMeterCount" class="value">0</div>
            </div>
          </div>
          <div class="col-6">
            <div class="state-card">
              <div class="label">Firmware</div>
              <div id="kpiFirmware" class="value">-</div>
            </div>
          </div>
          <div class="col-6">
            <div class="state-card">
              <div class="label">Scenario Mode</div>
              <div id="kpiScenarioSimple" class="value">Idle</div>
            </div>
          </div>
        </div>
      </div>

      <div class="panel span-6">
        <h3>EV Event Timeline</h3>
        <div id="eventLog" class="log" aria-live="polite"><div class="line info">[7:50:34 PM] EV cockpit ready. Follow Steps 1 to 5 for a complete, judge-friendly flow.</div></div>
      </div>

      <div class="panel span-6">
        <h3>API Details</h3>
        <pre id="apiResponse" class="log">{
  "method": "GET",
  "url": "http://localhost:8080/api/ev/profiles",
  "status": 200,
  "body": {
    "activeProfile": "normal",
    "availableProfiles": [
      "fast",
      "normal"
    ],
    "profiles": {
      "normal": {
        "heartbeatIntervalMs": 30000,
        "meterUpdateIntervalMs": 5000,
        "sessionDurationMs": 60000,
        "energyPerUpdateKwh": 1.5
      },
      "fast": {
        "heartbeatIntervalMs": 5000,
        "meterUpdateIntervalMs": 1000,
        "sessionDurationMs": 15000,
        "energyPerUpdateKwh": 0.5
      }
    }
  }
}</pre>
      </div>

      <div class="panel span-12">
        <details>
          <summary>Advanced Controls (technical)</summary>
          <div class="row">
            <div class="col-6"><button id="connectRawBtn" class="ok">POST /api/ev/connect</button></div>
            <div class="col-6"><button id="disconnectRawBtn" class="danger">POST /api/ev/disconnect</button></div>
            <div class="col-6"><button id="statusRawBtn" class="primary">GET /api/ev/status</button></div>
            <div class="col-6"><button id="profilesRawBtn" class="primary">GET /api/ev/profiles</button></div>
          </div>
        </details>
      </div>
    </div>
  </div>

  



</body></html>